{
  "name": "smarttrafficflow-latest-frontend",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite --port 5174",
    "build": "tsc --noEmit && tsc --project tsconfig.node.json --noEmit && vite build",
